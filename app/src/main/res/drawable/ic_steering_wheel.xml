<?xml version="1.0" encoding="utf-8"?>
<!-- Steering wheel — stroke-based to avoid EvenOdd fill-type API requirements.
     Matches the Y-spoke layout used in CustomIcons.SteeringWheel and the widget's
     drawSteeringWheel() canvas helper (spokes at 30°, 150°, 270° from right). -->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="24dp"
    android:height="24dp"
    android:viewportWidth="24"
    android:viewportHeight="24">
    <!-- Outer rim: circle r=10, center (12,12) -->
    <path
        android:pathData="M2,12 a10,10 0 1 0 20,0 a10,10 0 1 0 -20,0"
        android:fillColor="#00000000"
        android:strokeColor="#FFFFFF"
        android:strokeWidth="2" />
    <!-- Hub: circle r=2.8, center (12,12) -->
    <path
        android:pathData="M9.2,12 a2.8,2.8 0 1 0 5.6,0 a2.8,2.8 0 1 0 -5.6,0"
        android:fillColor="#00000000"
        android:strokeColor="#FFFFFF"
        android:strokeWidth="2" />
    <!-- Spoke top (270°): hub (12, 9.2) → rim (12, 2) -->
    <path
        android:pathData="M12,9.2 L12,2"
        android:strokeColor="#FFFFFF"
        android:strokeWidth="2"
        android:strokeLineCap="round" />
    <!-- Spoke lower-right (30°): hub (14.43, 13.4) → rim (20.66, 17) -->
    <path
        android:pathData="M14.43,13.4 L20.66,17"
        android:strokeColor="#FFFFFF"
        android:strokeWidth="2"
        android:strokeLineCap="round" />
    <!-- Spoke lower-left (150°): hub (9.57, 13.4) → rim (3.34, 17) -->
    <path
        android:pathData="M9.57,13.4 L3.34,17"
        android:strokeColor="#FFFFFF"
        android:strokeWidth="2"
        android:strokeLineCap="round" />
</vector>
